# SerpAPI Key — kostenlos bis 100 Anfragen/Monat
# Registrierung: https://serpapi.com/
SERPAPI_KEY=dein_serpapi_key_hier

# Google Maps Data ID für Gabriel
# Einmalig ermitteln: https://serpapi.com/search.json?engine=google_maps&q=Gabriel+Feine+Uhren+%26+Juwelen+K%C3%B6ln&api_key=DEIN_KEY
# Im JSON: local_results[0].data_id kopieren
GABRIEL_DATA_ID=0x47bf25a7b20e3ead:0x...

# Port (Railway setzt PORT automatisch)
PORT=3000

# Erlaubte Origins für CORS (Shopify-Domain des Shops)
ALLOWED_ORIGIN=https://gabriel-uhren.myshopify.com
